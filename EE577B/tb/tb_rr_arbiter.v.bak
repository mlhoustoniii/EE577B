`timescale 1ns/1ps

module tb_rr_arbiter;

reg clk, rst, polarity, buffer_free;
reg [3:0] request;
wire [3:0] grant;

rr_arbiter uut (
    .clk(clk),
    .rst(rst),
    .polarity(polarity),          	// 0=even cycle, 1=odd cycle
    .request(request),           	// One-hot requests from 4 input controllers (only 4 because a PE cannot request itself)
    .buffer_free(buffer_free),  	// Output buffer free? Driven by output_ctrl
    .grant(grant)              		// One-hot grant: combinational (Mealy)
);

always #2 clk = ~clk; // 250 MHz period
//always #4 polarity = ~polarity; // 250 MHz period

// Decode one-hot to requester index for readability
task decode_onehot;
    input [3:0] onehot;
    input [63:0] label;
    begin
        case (onehot)
            4'b0001: $write("%s: Requester 0  ", label);
            4'b0010: $write("%s: Requester 1  ", label);
            4'b0100: $write("%s: Requester 2  ", label);
            4'b1000: $write("%s: Requester 3  ", label);
            4'b0000: $write("%s: None         ", label);
            default: $write("%s: CONTENTION(%b)  ", label, onehot);
        endcase
    end
endtask

always @(posedge clk) begin
    $write("Time: %4t ns | VC: %s | ", $time, polarity ? "ODD " : "EVEN");
    decode_onehot(request, "REQ");
    decode_onehot(grant,   "GNT");
    $write("\n");
end

initial begin
    clk         = 0;
    rst         = 1;
    polarity    = 0;
    request     = 4'b0000;
    buffer_free = 1;

    #8 rst = 0;

    // Single requesters — no contention
    #8 request = 4'b0001; polarity = 0; // 1st requester, even VC
    #8 request = 4'b0010; polarity = 0; // 2nd requester, even VC
    #8 request = 4'b0100; polarity = 0; // 3rd requester, even VC
    #8 request = 4'b1000; polarity = 0; // 4th requester, even VC

    // Contention on EVEN VC — ptr should rotate 0→1→2→3→0
    #8 request = 4'b1111; polarity = 0; // contention round 1 → expect req 0
    #8 request = 4'b1111; polarity = 0; // contention round 2 → expect req 1
    #8 request = 4'b1111; polarity = 0; // contention round 3 → expect req 2
    #8 request = 4'b1111; polarity = 0; // contention round 4 → expect req 3

    #8 $stop;
end
endmodule