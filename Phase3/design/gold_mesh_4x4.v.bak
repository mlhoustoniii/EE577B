`timescale 1ns/1ps
// ============================================================
// gold_mesh_4x4.v
// Top-level 4x4 Mesh Network-on-Chip
//
// Instantiates 16 gold_router modules arranged in a 4x4 grid
// and wires them together using XY coordinate addressing.
//
// Node ID mapping: node_id = y*4 + x
//   (0,0)=0   (1,0)=1   (2,0)=2   (3,0)=3
//   (0,1)=4   (1,1)=5   (2,1)=6   (3,1)=7
//   (0,2)=8   (1,2)=9   (2,2)=10  (3,2)=11
//   (0,3)=12  (1,3)=13  (2,3)=14  (3,3)=15
//
// Grid Layout (Y increases upward):
//   (0,3)─(1,3)─(2,3)─(3,3)
//     │     │     │     │
//   (0,2)─(1,2)─(2,2)─(3,2)
//     │     │     │     │
//   (0,1)─(1,1)─(2,1)─(3,1)
//     │     │     │     │
//   (0,0)─(1,0)─(2,0)─(3,0)
//
// Edge port handling:
//   Ports that point off the grid have:
//     si  tied LOW  (no upstream sender)
//     di  tied LOW  (no data)
//     ro  tied HIGH (always ready, nothing will ever send)
//
// VC Injection Rules (for deadlock freedom):
//   Row 0 (y=0): even VC   Row 1 (y=1): odd  VC
//   Row 2 (y=2): even VC   Row 3 (y=3): odd  VC
//
// Packet Header Format (64-bit):
//   [63]     = VC polarity (0=even, 1=odd)
//   [62:61]  = Destination X (0-3)
//   [60:59]  = Destination Y (0-3)
//   [58:57]  = Source X
//   [56:55]  = Source Y
//   [54:32]  = Reserved
//   [31:0]   = Payload (destination node ID for gather testbench)
//
// Handshaking:
//   si/so: send signals (asserted when data is valid)
//   ri/ro: ready signals (asserted when buffer is empty/ready)
//   Transfer occurs when both s and r are high simultaneously
// ============================================================

module gold_mesh_4x4 (
    input  wire        clk,
    input  wire        reset,

    // -------------------------------------------------------
    // PE ports exposed to testbench for all 16 nodes
    // Naming: node{id}_pe{signal}
    // -------------------------------------------------------

    // Node 0 (0,0) PE
    input  wire        node0_pesi,
    output wire        node0_peri,
    input  wire [63:0] node0_pedi,
    output wire        node0_peso,
    input  wire        node0_pero,
    output wire [63:0] node0_pedo,
    output wire        node0_polarity,

    // Node 1 (1,0) PE
    input  wire        node1_pesi,
    output wire        node1_peri,
    input  wire [63:0] node1_pedi,
    output wire        node1_peso,
    input  wire        node1_pero,
    output wire [63:0] node1_pedo,
    output wire        node1_polarity,

    // Node 2 (2,0) PE
    input  wire        node2_pesi,
    output wire        node2_peri,
    input  wire [63:0] node2_pedi,
    output wire        node2_peso,
    input  wire        node2_pero,
    output wire [63:0] node2_pedo,
    output wire        node2_polarity,

    // Node 3 (3,0) PE
    input  wire        node3_pesi,
    output wire        node3_peri,
    input  wire [63:0] node3_pedi,
    output wire        node3_peso,
    input  wire        node3_pero,
    output wire [63:0] node3_pedo,
    output wire        node3_polarity,

    // Node 4 (0,1) PE
    input  wire        node4_pesi,
    output wire        node4_peri,
    input  wire [63:0] node4_pedi,
    output wire        node4_peso,
    input  wire        node4_pero,
    output wire [63:0] node4_pedo,
    output wire        node4_polarity,

    // Node 5 (1,1) PE
    input  wire        node5_pesi,
    output wire        node5_peri,
    input  wire [63:0] node5_pedi,
    output wire        node5_peso,
    input  wire        node5_pero,
    output wire [63:0] node5_pedo,
    output wire        node5_polarity,

    // Node 6 (2,1) PE
    input  wire        node6_pesi,
    output wire        node6_peri,
    input  wire [63:0] node6_pedi,
    output wire        node6_peso,
    input  wire        node6_pero,
    output wire [63:0] node6_pedo,
    output wire        node6_polarity,

    // Node 7 (3,1) PE
    input  wire        node7_pesi,
    output wire        node7_peri,
    input  wire [63:0] node7_pedi,
    output wire        node7_peso,
    input  wire        node7_pero,
    output wire [63:0] node7_pedo,
    output wire        node7_polarity,

    // Node 8 (0,2) PE
    input  wire        node8_pesi,
    output wire        node8_peri,
    input  wire [63:0] node8_pedi,
    output wire        node8_peso,
    input  wire        node8_pero,
    output wire [63:0] node8_pedo,
    output wire        node8_polarity,

    // Node 9 (1,2) PE
    input  wire        node9_pesi,
    output wire        node9_peri,
    input  wire [63:0] node9_pedi,
    output wire        node9_peso,
    input  wire        node9_pero,
    output wire [63:0] node9_pedo,
    output wire        node9_polarity,

    // Node 10 (2,2) PE
    input  wire        node10_pesi,
    output wire        node10_peri,
    input  wire [63:0] node10_pedi,
    output wire        node10_peso,
    input  wire        node10_pero,
    output wire [63:0] node10_pedo,
    output wire        node10_polarity,

    // Node 11 (3,2) PE
    input  wire        node11_pesi,
    output wire        node11_peri,
    input  wire [63:0] node11_pedi,
    output wire        node11_peso,
    input  wire        node11_pero,
    output wire [63:0] node11_pedo,
    output wire        node11_polarity,

    // Node 12 (0,3) PE
    input  wire        node12_pesi,
    output wire        node12_peri,
    input  wire [63:0] node12_pedi,
    output wire        node12_peso,
    input  wire        node12_pero,
    output wire [63:0] node12_pedo,
    output wire        node12_polarity,

    // Node 13 (1,3) PE
    input  wire        node13_pesi,
    output wire        node13_peri,
    input  wire [63:0] node13_pedi,
    output wire        node13_peso,
    input  wire        node13_pero,
    output wire [63:0] node13_pedo,
    output wire        node13_polarity,

    // Node 14 (2,3) PE
    input  wire        node14_pesi,
    output wire        node14_peri,
    input  wire [63:0] node14_pedi,
    output wire        node14_peso,
    input  wire        node14_pero,
    output wire [63:0] node14_pedo,
    output wire        node14_polarity,

    // Node 15 (3,3) PE
    input  wire        node15_pesi,
    output wire        node15_peri,
    input  wire [63:0] node15_pedi,
    output wire        node15_peso,
    input  wire        node15_pero,
    output wire [63:0] node15_pedo,
    output wire        node15_polarity
);

    // -------------------------------------------------------
    // Internal inter-router link wires
    // Naming convention: {dir}_{src_x}{src_y}_to_{dst_x}{dst_y}
    //
    // For horizontal (East-West) links:
    //   so_x{x}y{y}_e = send from router(x,y) going East
    //   ro_x{x}y{y}_e = ready from router(x,y) going East
    //   do_x{x}y{y}_e = data from router(x,y) going East
    //
    // For vertical (North-South) links:
    //   so_x{x}y{y}_n = send from router(x,y) going North
    //   ro_x{x}y{y}_n = ready from router(x,y) going North
    //   do_x{x}y{y}_n = data from router(x,y) going North
    // -------------------------------------------------------

    // -------------------------------------------------------
    // Horizontal links (East-West connections)
    // Each horizontal link connects router(x,y) East port
    // to router(x+1,y) West port
    // -------------------------------------------------------

    // Row y=0 horizontal links
    wire        so_x0y0_e; wire ro_x0y0_e; wire [63:0] do_x0y0_e; // (0,0)→E→(1,0)
    wire        so_x1y0_e; wire ro_x1y0_e; wire [63:0] do_x1y0_e; // (1,0)→E→(2,0)
    wire        so_x2y0_e; wire ro_x2y0_e; wire [63:0] do_x2y0_e; // (2,0)→E→(3,0)
    wire        so_x1y0_w; wire ro_x1y0_w; wire [63:0] do_x1y0_w; // (1,0)←W←(0,0) reverse
    wire        so_x2y0_w; wire ro_x2y0_w; wire [63:0] do_x2y0_w; // (2,0)←W←(1,0)
    wire        so_x3y0_w; wire ro_x3y0_w; wire [63:0] do_x3y0_w; // (3,0)←W←(2,0)

    // Row y=1 horizontal links
    wire        so_x0y1_e; wire ro_x0y1_e; wire [63:0] do_x0y1_e;
    wire        so_x1y1_e; wire ro_x1y1_e; wire [63:0] do_x1y1_e;
    wire        so_x2y1_e; wire ro_x2y1_e; wire [63:0] do_x2y1_e;
    wire        so_x1y1_w; wire ro_x1y1_w; wire [63:0] do_x1y1_w;
    wire        so_x2y1_w; wire ro_x2y1_w; wire [63:0] do_x2y1_w;
    wire        so_x3y1_w; wire ro_x3y1_w; wire [63:0] do_x3y1_w;

    // Row y=2 horizontal links
    wire        so_x0y2_e; wire ro_x0y2_e; wire [63:0] do_x0y2_e;
    wire        so_x1y2_e; wire ro_x1y2_e; wire [63:0] do_x1y2_e;
    wire        so_x2y2_e; wire ro_x2y2_e; wire [63:0] do_x2y2_e;
    wire        so_x1y2_w; wire ro_x1y2_w; wire [63:0] do_x1y2_w;
    wire        so_x2y2_w; wire ro_x2y2_w; wire [63:0] do_x2y2_w;
    wire        so_x3y2_w; wire ro_x3y2_w; wire [63:0] do_x3y2_w;

    // Row y=3 horizontal links
    wire        so_x0y3_e; wire ro_x0y3_e; wire [63:0] do_x0y3_e;
    wire        so_x1y3_e; wire ro_x1y3_e; wire [63:0] do_x1y3_e;
    wire        so_x2y3_e; wire ro_x2y3_e; wire [63:0] do_x2y3_e;
    wire        so_x1y3_w; wire ro_x1y3_w; wire [63:0] do_x1y3_w;
    wire        so_x2y3_w; wire ro_x2y3_w; wire [63:0] do_x2y3_w;
    wire        so_x3y3_w; wire ro_x3y3_w; wire [63:0] do_x3y3_w;

    // -------------------------------------------------------
    // Vertical links (North-South connections)
    // Each vertical link connects router(x,y) North port
    // to router(x,y+1) South port
    // -------------------------------------------------------

    // Column x=0 vertical links
    wire        so_x0y0_n; wire ro_x0y0_n; wire [63:0] do_x0y0_n; // (0,0)→N→(0,1)
    wire        so_x0y1_n; wire ro_x0y1_n; wire [63:0] do_x0y1_n; // (0,1)→N→(0,2)
    wire        so_x0y2_n; wire ro_x0y2_n; wire [63:0] do_x0y2_n; // (0,2)→N→(0,3)
    wire        so_x0y1_s; wire ro_x0y1_s; wire [63:0] do_x0y1_s; // (0,1)←S←(0,0) reverse
    wire        so_x0y2_s; wire ro_x0y2_s; wire [63:0] do_x0y2_s;
    wire        so_x0y3_s; wire ro_x0y3_s; wire [63:0] do_x0y3_s;

    // Column x=1 vertical links
    wire        so_x1y0_n; wire ro_x1y0_n; wire [63:0] do_x1y0_n;
    wire        so_x1y1_n; wire ro_x1y1_n; wire [63:0] do_x1y1_n;
    wire        so_x1y2_n; wire ro_x1y2_n; wire [63:0] do_x1y2_n;
    wire        so_x1y1_s; wire ro_x1y1_s; wire [63:0] do_x1y1_s;
    wire        so_x1y2_s; wire ro_x1y2_s; wire [63:0] do_x1y2_s;
    wire        so_x1y3_s; wire ro_x1y3_s; wire [63:0] do_x1y3_s;

    // Column x=2 vertical links
    wire        so_x2y0_n; wire ro_x2y0_n; wire [63:0] do_x2y0_n;
    wire        so_x2y1_n; wire ro_x2y1_n; wire [63:0] do_x2y1_n;
    wire        so_x2y2_n; wire ro_x2y2_n; wire [63:0] do_x2y2_n;
    wire        so_x2y1_s; wire ro_x2y1_s; wire [63:0] do_x2y1_s;
    wire        so_x2y2_s; wire ro_x2y2_s; wire [63:0] do_x2y2_s;
    wire        so_x2y3_s; wire ro_x2y3_s; wire [63:0] do_x2y3_s;

    // Column x=3 vertical links
    wire        so_x3y0_n; wire ro_x3y0_n; wire [63:0] do_x3y0_n;
    wire        so_x3y1_n; wire ro_x3y1_n; wire [63:0] do_x3y1_n;
    wire        so_x3y2_n; wire ro_x3y2_n; wire [63:0] do_x3y2_n;
    wire        so_x3y1_s; wire ro_x3y1_s; wire [63:0] do_x3y1_s;
    wire        so_x3y2_s; wire ro_x3y2_s; wire [63:0] do_x3y2_s;
    wire        so_x3y3_s; wire ro_x3y3_s; wire [63:0] do_x3y3_s;

    // -------------------------------------------------------
    // Router Instantiations — 16 total
    //
    // Port connection rules:
    //   North port: connects to router above (y+1)
    //     nsi = so from router(x,y+1) south output
    //     nro = ro from router(x,y+1) south input
    //   South port: connects to router below (y-1)
    //   East port:  connects to router right (x+1)
    //   West port:  connects to router left  (x-1)
    //
    // Edge port tie-off rules:
    //   si=0, di=64'b0 (no upstream sender)
    //   ro=1           (always ready, upstream will never send)
    // -------------------------------------------------------

    // -------------------------------------------------------
    // ROW y=0: Nodes 0,1,2,3
    // South ports ALL tied off (bottom edge)
    // -------------------------------------------------------

    // Node 0: (x=0, y=0) — bottom-left corner
    // North connects to (0,1), East connects to (1,0)
    // South tied off (bottom edge), West tied off (left edge)
    gold_router #(.ROUTER_X(0), .ROUTER_Y(0)) router_x0y0 (
        .clk      (clk),
        .reset    (reset),
        .polarity (node0_polarity),
        // North port → connects to router(0,1) south port
        .nsi      (so_x0y1_s),
        .nri      (ro_x0y1_s),
        .ndi      (do_x0y1_s),
        .nso      (so_x0y0_n),
        .nro      (ro_x0y0_n),
        .ndo      (do_x0y0_n),
        // South port — TIED OFF (bottom edge)
        .ssi      (1'b0),
        .sri      (),
        .sdi      (64'b0),
        .sso      (),
        .sro      (1'b1),
        .sdo      (),
        // East port → connects to router(1,0) west port
        .esi      (so_x1y0_w),
        .eri      (ro_x1y0_w),
        .edi      (do_x1y0_w),
        .eso      (so_x0y0_e),
        .ero      (ro_x0y0_e),
        .edo      (do_x0y0_e),
        // West port — TIED OFF (left edge)
        .wsi      (1'b0),
        .wri      (),
        .wdi      (64'b0),
        .wso      (),
        .wro      (1'b1),
        .wdo      (),
        // PE port
        .pesi     (node0_pesi),
        .peri     (node0_peri),
        .pedi     (node0_pedi),
        .peso     (node0_peso),
        .pero     (node0_pero),
        .pedo     (node0_pedo)
    );

    // Node 1: (x=1, y=0) — bottom row, second from left
    // North→(1,1), East→(2,0), West←(0,0)
    // South tied off (bottom edge)
    gold_router #(.ROUTER_X(1), .ROUTER_Y(0)) router_x1y0 (
        .clk      (clk),
        .reset    (reset),
        .polarity (node1_polarity),
        // North port → connects to router(1,1) south port
        .nsi      (so_x1y1_s),
        .nri      (ro_x1y1_s),
        .ndi      (do_x1y1_s),
        .nso      (so_x1y0_n),
        .nro      (ro_x1y0_n),
        .ndo      (do_x1y0_n),
        // South port — TIED OFF (bottom edge)
        .ssi      (1'b0),
        .sri      (),
        .sdi      (64'b0),
        .sso      (),
        .sro      (1'b1),
        .sdo      (),
        // East port → connects to router(2,0) west port
        .esi      (so_x2y0_w),
        .eri      (ro_x2y0_w),
        .edi      (do_x2y0_w),
        .eso      (so_x1y0_e),
        .ero      (ro_x1y0_e),
        .edo      (do_x1y0_e),
        // West port → connects to router(0,0) east port
        .wsi      (so_x0y0_e),
        .wri      (ro_x0y0_e),
        .wdi      (do_x0y0_e),
        .wso      (so_x1y0_w),
        .wro      (ro_x1y0_w),
        .wdo      (do_x1y0_w),
        // PE port
        .pesi     (node1_pesi),
        .peri     (node1_peri),
        .pedi     (node1_pedi),
        .peso     (node1_peso),
        .pero     (node1_pero),
        .pedo     (node1_pedo)
    );

    // Node 2: (x=2, y=0) — bottom row, second from right
    // North→(2,1), East→(3,0), West←(1,0)
    // South tied off (bottom edge)
    gold_router #(.ROUTER_X(2), .ROUTER_Y(0)) router_x2y0 (
        .clk      (clk),
        .reset    (reset),
        .polarity (node2_polarity),
        .nsi      (so_x2y1_s),
        .nri      (ro_x2y1_s),
        .ndi      (do_x2y1_s),
        .nso      (so_x2y0_n),
        .nro      (ro_x2y0_n),
        .ndo      (do_x2y0_n),
        // South — TIED OFF
        .ssi      (1'b0),
        .sri      (),
        .sdi      (64'b0),
        .sso      (),
        .sro      (1'b1),
        .sdo      (),
        // East → router(3,0) west
        .esi      (so_x3y0_w),
        .eri      (ro_x3y0_w),
        .edi      (do_x3y0_w),
        .eso      (so_x2y0_e),
        .ero      (ro_x2y0_e),
        .edo      (do_x2y0_e),
        // West → router(1,0) east
        .wsi      (so_x1y0_e),
        .wri      (ro_x1y0_e),
        .wdi      (do_x1y0_e),
        .wso      (so_x2y0_w),
        .wro      (ro_x2y0_w),
        .wdo      (do_x2y0_w),
        .pesi     (node2_pesi),
        .peri     (node2_peri),
        .pedi     (node2_pedi),
        .peso     (node2_peso),
        .pero     (node2_pero),
        .pedo     (node2_pedo)
    );

    // Node 3: (x=3, y=0) — bottom-right corner
    // North→(3,1), West←(2,0)
    // South tied off (bottom edge), East tied off (right edge)
    gold_router #(.ROUTER_X(3), .ROUTER_Y(0)) router_x3y0 (
        .clk      (clk),
        .reset    (reset),
        .polarity (node3_polarity),
        .nsi      (so_x3y1_s),
        .nri      (ro_x3y1_s),
        .ndi      (do_x3y1_s),
        .nso      (so_x3y0_n),
        .nro      (ro_x3y0_n),
        .ndo      (do_x3y0_n),
        // South — TIED OFF
        .ssi      (1'b0),
        .sri      (),
        .sdi      (64'b0),
        .sso      (),
        .sro      (1'b1),
        .sdo      (),
        // East — TIED OFF (right edge)
        .esi      (1'b0),
        .eri      (),
        .edi      (64'b0),
        .eso      (),
        .ero      (1'b1),
        .edo      (),
        // West → router(2,0) east
        .wsi      (so_x2y0_e),
        .wri      (ro_x2y0_e),
        .wdi      (do_x2y0_e),
        .wso      (so_x3y0_w),
        .wro      (ro_x3y0_w),
        .wdo      (do_x3y0_w),
        .pesi     (node3_pesi),
        .peri     (node3_peri),
        .pedi     (node3_pedi),
        .peso     (node3_peso),
        .pero     (node3_pero),
        .pedo     (node3_pedo)
    );

    // -------------------------------------------------------
    // ROW y=1: Nodes 4,5,6,7
    // All have both North and South connections
    // -------------------------------------------------------

    // Node 4: (x=0, y=1) — left edge
    // North→(0,2), South←(0,0)
    // West tied off (left edge)
    gold_router #(.ROUTER_X(0), .ROUTER_Y(1)) router_x0y1 (
        .clk      (clk),
        .reset    (reset),
        .polarity (node4_polarity),
        // North → router(0,2) south
        .nsi      (so_x0y2_s),
        .nri      (ro_x0y2_s),
        .ndi      (do_x0y2_s),
        .nso      (so_x0y1_n),
        .nro      (ro_x0y1_n),
        .ndo      (do_x0y1_n),
        // South → router(0,0) north
        .ssi      (so_x0y0_n),
        .sri      (ro_x0y0_n),
        .sdi      (do_x0y0_n),
        .sso      (so_x0y1_s),
        .sro      (ro_x0y1_s),
        .sdo      (do_x0y1_s),
        // East → router(1,1) west
        .esi      (so_x1y1_w),
        .eri      (ro_x1y1_w),
        .edi      (do_x1y1_w),
        .eso      (so_x0y1_e),
        .ero      (ro_x0y1_e),
        .edo      (do_x0y1_e),
        // West — TIED OFF (left edge)
        .wsi      (1'b0),
        .wri      (),
        .wdi      (64'b0),
        .wso      (),
        .wro      (1'b1),
        .wdo      (),
