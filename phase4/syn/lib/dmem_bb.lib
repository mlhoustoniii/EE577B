        pin (dataIn[46]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[45]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[44]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[43]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
