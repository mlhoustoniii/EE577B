/* =========================================================
   dmem_bb.lib  --  Liberty blackbox timing model for dmem
   EE 577B Spring 2026, Phase 4

   Purpose: Give DC real setup-check timing arcs on every
   dmem input so the entire CPU→DMEM write path is preserved,
   and a real clock-to-Q arc on dataOut so the DMEM→CPU
   read path is preserved.

   Model:
     - All data inputs (dataIn, memAddr, memEn, memWrEn)
       have setup time relative to clk posedge
     - dataOut has clock-to-Q delay from clk (registered read)
       matching the Phase-3 dmem behavior (1-cycle registered)
   ========================================================= */

library (dmem_bb) {
    technology (cmos);
    delay_model : table_lookup;
    time_unit : "1ns";
    voltage_unit : "1V";
    current_unit : "1mA";
    leakage_power_unit : "1nW";
    pulling_resistance_unit : "1kohm";
    capacitive_load_unit (1, pf);

    default_fanout_load      : 1.0;
    default_inout_pin_cap    : 1.0;
    default_input_pin_cap    : 1.0;
    default_output_pin_cap   : 0.0;
    default_cell_leakage_power : 0.0;

    lu_table_template (setup_tmpl) {
        variable_1 : constrained_pin_transition;
        index_1 ("0.5");
    }
    lu_table_template (clkq_tmpl) {
        variable_1 : input_net_transition;
        index_1 ("0.5");
    }

    cell (dmem) {
        area : 1000.0;
        dont_touch : true;
        dont_use   : true;

        /* Clock pin */
        pin (clk) {
            direction : input;
            capacitance : 0.01;
            clock : true;
        }

        /* Control inputs -- setup check against clk */
        pin (memEn) {
            direction : input;
            capacitance : 0.01;
            timing () {
                related_pin : "clk";
                timing_type : setup_rising;
                rise_constraint (setup_tmpl) { values ("0.094"); }
                fall_constraint (setup_tmpl) { values ("0.094"); }
            }
        }
        pin (memWrEn) {
            direction : input;
            capacitance : 0.01;
            timing () {
                related_pin : "clk";
                timing_type : setup_rising;
                rise_constraint (setup_tmpl) { values ("0.094"); }
                fall_constraint (setup_tmpl) { values ("0.094"); }
            }
        }

        /* Address inputs -- setup check against clk */
        pin (memAddr[7]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[6]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[5]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[4]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[3]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[2]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[1]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (memAddr[0]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}

        /* Data inputs -- setup check against clk */
        pin (dataIn[63]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[62]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[61]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[60]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[59]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[58]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[57]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[56]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[55]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[54]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[53]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[52]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[51]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[50]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[49]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
        pin (dataIn[48]) { direction:input; capacitance:0.01; timing(){related_pin:"clk"; timing_type:setup_rising; rise_constraint(setup_tmpl){values("0.094");} fall_constraint(setup_tmpl){values("0.094");}}}
